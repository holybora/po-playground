# Polymarket Arb Bot Configuration
# All values have sensible defaults -- only override what you need

# CLOB_BASE_URL=https://clob.polymarket.com
# GAMMA_BASE_URL=https://gamma-api.polymarket.com
# CHAIN_ID=137

# MAX_MARKETS=50
# MIN_LIQUIDITY_USD=5000
# MIN_VOLUME_USD=1000
# MARKET_REFRESH_MS=300000

# PRICE_POLL_MS=2000
# STALE_PRICE_MS=10000

# ARB_THRESHOLD=0.998
# MIN_PROFIT_BPS=20
# FEE_RATE_BPS=0

# POSITION_SIZE_USD=100
# MAX_OPEN_POSITIONS=20
# MAX_POS_PER_MARKET=1

# PERSIST_TO_FILE=true
# DATA_DIR=./data

# LOG_LEVEL=info
